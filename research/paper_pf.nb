Cell[BoxData[
 RowBox[{
  RowBox[{"PMFS", "[", 
   RowBox[{"n_", ",", "S_"}], "]"}], ":=", 
  RowBox[{
   SuperscriptBox["2", 
    RowBox[{
     RowBox[{"-", "S"}], "*", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"l", "*", 
        SuperscriptBox["2", 
         RowBox[{"-", "l"}]]}], ",", 
       RowBox[{"{", 
        RowBox[{"l", ",", "1", ",", 
         RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}]], "*", 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     SuperscriptBox["2", 
      RowBox[{
       RowBox[{"-", "S"}], "*", "n", "*", 
       SuperscriptBox["2", "n"]}]]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.7078559497416725`*^9, 3.707855977556567*^9}, {
